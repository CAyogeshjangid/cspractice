# Praxis — every env var the app reads, with safe placeholders. (Charter C6/C8)
# Copy to .env and fill in. The app REFUSES TO START if a required var is missing.

# --- Required ---
DATABASE_URL=postgresql+asyncpg://praxis:CHANGE_ME@postgres:5432/praxis
REDIS_URL=redis://redis:6379/0
JWT_SECRET=CHANGE_ME_generate_with__python -c "import secrets;print(secrets.token_urlsafe(48))"
CSRF_SECRET=CHANGE_ME_generate_with__python -c "import secrets;print(secrets.token_urlsafe(48))"
# Comma-separated explicit origins. Never '*'. App refuses to start if unset. (C1)
CORS_ORIGINS=http://localhost:5173

# --- Optional (defaults shown) ---
ENV=dev                        # dev | prod  (prod forces Secure cookies)
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=7
RATE_LIMIT_PER_MINUTE=120
AUTH_RATE_LIMIT_PER_MINUTE=10
STORAGE_DIR=/data              # generated documents root (named volume in prod)

# --- Postgres container bootstrap (docker-compose only) ---
POSTGRES_USER=praxis
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=praxis
